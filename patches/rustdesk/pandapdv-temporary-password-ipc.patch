+#[cfg(windows)]
+fn panda_remote_support_dir() -> PathBuf {
+    let base = std::env::var_os("ProgramData")
+        .map(PathBuf::from)
+        .unwrap_or_else(|| PathBuf::from(r"C:\ProgramData"));
+    base.join("PandaPDV").join("RemoteSupport")
+}
+
+#[cfg(windows)]
+fn panda_remote_support_secret_path(base_dir: &Path) -> PathBuf {
