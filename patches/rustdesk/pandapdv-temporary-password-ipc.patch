+#[cfg(windows)]
+pub fn set_panda_session_password(password: &str, ttl_secs: u64) -> bool {
+    const MIN_TTL_SECS: u64 = 30;
+    const MAX_TTL_SECS: u64 = 3_600;
+
+    if password.is_empty() || password.chars().count() > crate::config::ENCRYPT_MAX_LEN {
+        return false;
+    }
+    if !(MIN_TTL_SECS..=MAX_TTL_SECS).contains(&ttl_secs) {
+        return false;
+    }
+
+    let mut panda_session_password = PANDA_SESSION_PASSWORD.write().unwrap();
+
+    *panda_session_password = Some(PandaSessionPassword {
+        password: password.to_owned(),
+        expires_at: Instant::now() + std::time::Duration::from_secs(ttl_secs),
+    });
+    true
+}
+
+pub fn clear_panda_session_password() {
+    *PANDA_SESSION_PASSWORD.write().unwrap() = None;
+}
+
+fn clear_panda_session_password_state() {
+    *PANDA_SESSION_PASSWORD.write().unwrap() = None;
+}
+
+fn expire_panda_session_password_if_needed() {
+    let expired = PANDA_SESSION_PASSWORD
+        .read()
+        .unwrap()
+        .as_ref()
+        .map(|state| Instant::now() >= state.expires_at)
+        .unwrap_or(false);
+    if expired {
