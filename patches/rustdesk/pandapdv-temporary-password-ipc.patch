+}
+
+#[cfg(windows)]
+fn unix_timestamp_secs() -> u64 {
+    std::time::SystemTime::now()
+        .duration_since(std::time::UNIX_EPOCH)
+        .unwrap_or_default()
+        .as_secs()
+}
+
+#[cfg(windows)]
+fn canonical_panda_session_password_message(request: &PandaSessionPasswordRequest) -> String {
+    format!(
+        "{}\n{}\n{}\n{}\n{}",
+        request.request_id, request.expires_at, request.action, request.ttl_secs, request.password
+    )
+}
+
+#[cfg(windows)]
+fn hex_decode(value: &str) -> Option<Vec<u8>> {
+    if value.len() % 2 != 0 {
+        return None;
+    }
+    let mut out = Vec::with_capacity(value.len() / 2);
+    for pair in value.as_bytes().chunks_exact(2) {
+        let hi = (pair[0] as char).to_digit(16)?;
+        let lo = (pair[1] as char).to_digit(16)?;
+        out.push(((hi << 4) | lo) as u8);
+    }
+    Some(out)
+}
+
+#[cfg(windows)]
+fn read_panda_session_password_request(
+    request_path: &str,
+) -> ResultType<PandaSessionPasswordRequest> {
+    let base_dir = panda_remote_support_dir().canonicalize()?;
+    let request_path = Path::new(request_path).canonicalize()?;
+    if !request_path.starts_with(&base_dir) {
+        bail!("Panda request file is outside the RemoteSupport directory");
+    }
+
+    let request: PandaSessionPasswordRequest =
+        serde_json::from_str(&std::fs::read_to_string(&request_path)?)?;
+    if request.request_id.trim().is_empty() || request.request_id.len() > 128 {
+        bail!("Invalid Panda request id");
+    }
+    if request.action != PANDA_SESSION_PASSWORD_ACTION {
+        bail!("Panda request action mismatch");
+    }
+    if request.expires_at <= unix_timestamp_secs() {
+        bail!("Panda request is expired");
+    }
+
+    let Some(signature) = hex_decode(&request.signature) else {
+        bail!("Invalid Panda request signature encoding");
+    };
+
+    let secret = std::fs::read(panda_remote_support_secret_path(&base_dir))?;
+    let mut mac = HmacSha256::new_from_slice(&secret)
+        .map_err(|_| hbb_common::anyhow::anyhow!("Invalid Panda request secret"))?;
+    mac.update(canonical_panda_session_password_message(&request).as_bytes());
+    mac.verify_slice(&signature)
+        .map_err(|_| hbb_common::anyhow::anyhow!("Invalid Panda request signature"))?;
+
+    let mut replay_cache = PANDA_SESSION_PASSWORD_REPLAY_CACHE.lock().unwrap();
+    if !replay_cache.insert(request.request_id.clone()) {
+        bail!("Panda request was already used");
+    }
+
+    Ok(request)
+}
