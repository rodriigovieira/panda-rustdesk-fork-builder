+pub async fn set_panda_session_password_with_ack(request_path: String) -> ResultType<bool> {
+    let ms_timeout = 1_000;
+    let mut c = connect(ms_timeout, "").await?;
+    c.send_config(PANDA_SESSION_PASSWORD_CONFIG, request_path)
+        .await?;
